{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.4",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/build/(.*)",
      "dest": "/public/build/$1"
    },
    {
      "src": "/(favicon.ico|favicon.svg|apple-touch-icon.png|robots.txt)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*\\.(?:css|js|mjs|json|png|jpg|jpeg|gif|svg|webp|ico|txt|woff|woff2|ttf|eot))",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr",
    "CACHE_STORE": "array",
    "QUEUE_CONNECTION": "sync",
    "SESSION_DRIVER": "database",
    "APP_CONFIG_CACHE": "/tmp/laravel/config.php",
    "APP_EVENTS_CACHE": "/tmp/laravel/events.php",
    "APP_PACKAGES_CACHE": "/tmp/laravel/packages.php",
    "APP_ROUTES_CACHE": "/tmp/laravel/routes.php",
    "APP_SERVICES_CACHE": "/tmp/laravel/services.php",
    "VIEW_COMPILED_PATH": "/tmp/laravel/views",
    "COMPOSER_VERSION": "2"
  }
}
