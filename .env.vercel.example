APP_NAME="Nguevela Barber"
APP_ENV=production
APP_KEY=base64:generate_a_real_key_with_php_artisan_key_generate_show
APP_DEBUG=false
APP_URL=https://your-project.vercel.app

APP_LOCALE=pt
APP_FALLBACK_LOCALE=pt
APP_FAKER_LOCALE=pt_PT
BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_LEVEL=error

# Use an external database in production. SQLite in the repo is not persistent on Vercel.
DB_CONNECTION=mysql
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Serverless-safe defaults.
CACHE_STORE=array
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
QUEUE_CONNECTION=sync
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Writable paths for Laravel when running inside Vercel functions.
APP_CONFIG_CACHE=/tmp/laravel/config.php
APP_EVENTS_CACHE=/tmp/laravel/events.php
APP_PACKAGES_CACHE=/tmp/laravel/packages.php
APP_ROUTES_CACHE=/tmp/laravel/routes.php
APP_SERVICES_CACHE=/tmp/laravel/services.php
VIEW_COMPILED_PATH=/tmp/laravel/views

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
